digraph DenseDepthHeadIncrement {
  graph [
    rankdir=LR,
    bgcolor="white",
    pad=0.25,
    nodesep=0.45,
    ranksep=0.70,
    splines=true,
    fontname="Helvetica",
    fontsize=18,
    labelloc=t,
    label="Incremental change: add gated adapter + dense depth head supervision"
  ];

  node [
    shape=box,
    style="rounded,filled",
    fontname="Helvetica",
    fontsize=12,
    color="#334155",
    fillcolor="#f8fafc",
    penwidth=1.2,
    margin="0.10,0.08"
  ];

  edge [
    fontname="Helvetica",
    fontsize=11,
    color="#334155",
    arrowsize=0.75,
    penwidth=1.3
  ];

  input [
    label="Input frames\n5 camera frames + LiDAR",
    fillcolor="#eff6ff"
  ];

  frontend [
    label="Original front-end\nFrozen OccAny backbone\n+ LiDAR-image fusion\n+ token_projector",
    fillcolor="#e0f2fe"
  ];

  feat [
    label="feat_2d\n(B,N,256,10,32)",
    fillcolor="#e0f2fe"
  ];

  lss [
    label="Original occupancy path\nLSS lift + LiDAR memory\n+ 3D occ head",
    fillcolor="#ecfeff"
  ];

  occ_logits [
    label="ssc_logit",
    fillcolor="#ede9fe"
  ];

  occ_loss [
    label="occupancy loss\nCE + Lovasz",
    fillcolor="#fff1f2",
    color="#e11d48"
  ];

  input -> frontend -> feat;
  feat -> lss [label="baseline direct path"];
  lss -> occ_logits -> occ_loss;

  subgraph cluster_increment {
    label="Added increment for dense depth head supervision";
    color="#f97316";
    penwidth=2.0;
    style="rounded";

    adapter [
      label="1. SharedGeometryAdapter\nmulti-scale 2D geometry branch\nproduces shared_geometry_feat and delta",
      fillcolor="#ffedd5",
      color="#ea580c",
      penwidth=1.6
    ];

    gate [
      label="2. Gated residual merge\nfeat_2d_refined = feat_2d + alpha * delta\nalpha init = 0.0",
      fillcolor="#fde68a",
      color="#d97706",
      penwidth=1.8
    ];

    depth_head [
      label="3. DenseDepthHead\nshared_geometry_feat[:, target frame]\n-> pred_dense_depth\n(B,1,H,W)",
      fillcolor="#ffedd5",
      color="#ea580c",
      penwidth=1.6
    ];

    dense_gt [
      label="Dense depth GT\nviews[0].dense_depth\nKITTI depth-completion map",
      fillcolor="#fef3c7",
      color="#d97706"
    ];

    dense_loss [
      label="4. dense_depth_loss\nlog-depth L1 + SI term\nweighted by --dense_depth_loss_weight",
      fillcolor="#fff7ed",
      color="#f97316",
      penwidth=1.8
    ];

    total_loss [
      label="total loss\noccupancy loss + dense_depth_weighted",
      fillcolor="#fee2e2",
      color="#dc2626",
      penwidth=2.0
    ];
  }

  feat -> adapter [
    label="enable --shared_geometry_adapter",
    color="#f97316",
    penwidth=2.0
  ];

  adapter -> gate [
    label="delta",
    color="#f97316",
    penwidth=2.0
  ];

  feat -> gate [
    label="identity residual",
    style=dashed,
    color="#d97706"
  ];

  gate -> lss [
    label="replace baseline input with feat_2d_refined",
    color="#f97316",
    penwidth=2.0
  ];

  adapter -> depth_head [
    label="shared_geometry_feat",
    color="#f97316",
    penwidth=2.0
  ];

  depth_head -> dense_loss [
    label="pred_dense_depth",
    color="#f97316",
    penwidth=2.0
  ];

  dense_gt -> dense_loss [
    label="target frame only",
    color="#d97706"
  ];

  occ_loss -> total_loss;
  dense_loss -> total_loss [
    label="added supervision",
    color="#f97316",
    penwidth=2.0
  ];

  note [
    label="Not shown / not included here:\nLSS depth-logit supervision\n(--dense_lss_depth_supervision)",
    shape=note,
    fillcolor="#f1f5f9",
    color="#94a3b8",
    fontcolor="#475569"
  ];

  note -> lss [
    style=dashed,
    color="#94a3b8",
    arrowhead=none
  ];
}
